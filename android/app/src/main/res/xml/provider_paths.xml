<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths for the in-app updater: lets the Android package
     installer read the APK that react-native-blob-util downloaded into the
     app's private cache/files dirs (content:// URI with a read grant). -->
<paths>
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
    <external-path name="external" path="." />
    <external-cache-path name="external_cache" path="." />
    <external-files-path name="external_files" path="." />
</paths>
